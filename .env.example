# Comma-separated list of allowed CORS origins (frontend URLs).
# Leave as "*" only for local dev.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# rembg model name. Options: u2net (default, ~170MB), u2netp (4.7MB, lower quality),
# u2net_human_seg, isnet-general-use, birefnet-general (best, larger).
REMBG_MODEL=u2net

# Max upload size in MB
MAX_UPLOAD_MB=10
